  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'A ball will approach you from a distance.



    Your task is to predict
    whether it will HIT you or MISS you.



    The ball will disappear before reaching
    you,



    so you must judge from its trajectory.



    Press the LEFT trigger
    if you think it will HIT you.



    Press the RIGHT trigger if you think it
    will MISS you.



    Respond as quickly and accurately as you can.



    There
    are 80 trials per block. Please stay still.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
