%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 90a31742b4988d64896200d05b98a005, type: 3}
  m_Name: HitOrMissTermTable
  m_EditorClassIdentifier: 
  m_Entries:
  - key: instruction_title
    english: Hit or Miss
    french: "Touche ou Rat\xE9"
  - key: instruction_body
    english: 'A ball will approach you from a distance.

      Your task is to predict
      whether it will HIT you or MISS you.


      The ball will disappear before
      reaching you,

      so you must judge from its trajectory.


      Press the
      LEFT trigger if you think it will HIT you.

      Press the RIGHT trigger if
      you think it will MISS you.


      Respond as quickly and accurately as you
      can.

      There are 80 trials per block. Please stay still.'
    french: "Une balle s'approchera de vous depuis une certaine distance.\nVotre
      t\xE2che est de pr\xE9dire si elle va vous TOUCHER ou vous RATER.\n\nLa balle
      dispara\xEEtra avant de vous atteindre,\nvous devez donc juger \xE0 partir
      de sa trajectoire.\n\nAppuyez sur la g\xE2chette GAUCHE si vous pensez qu'elle
      va vous TOUCHER.\nAppuyez sur la g\xE2chette DROITE si vous pensez qu'elle
      va vous RATER.\n\nR\xE9pondez aussi vite et pr\xE9cis\xE9ment que possible.\nIl
      y a 80 essais par bloc. Veuillez rester immobile."
  - key: block_complete
    english: "Block completed \u2014 take a small break"
    french: "Bloc termin\xE9 \u2014 faites une courte pause"
  - key: experiment_end
    english: "End of the experiment \u2014 Thank you!"
    french: "Fin de l'exp\xE9rience \u2014 Merci !"
  - key: rest_message
    english: Please rest. The next block will begin shortly.
    french: "Veuillez vous reposer. Le prochain bloc commencera bient\xF4t."
  - key: ready
    english: Ready
    french: "Pr\xEAt"
  - key: say_hit
    english: HIT
    french: TOUCHE
  - key: say_miss
    english: MISS
    french: "RAT\xC9"
  - key: pps.instructions
    english: "In this experiment, you will see two lights approaching you.\n\nOccasionally,
      you will feel a brief vibration on your chest.\n\nYour goal is to:\n  \u2022
      Focus on the approaching lights.\n  \u2022 Respond as quickly as possible when
      you feel the vibration.\n  \u2022 Press the response button the moment you
      detect the touch.\n\nKeep your hand ready on the button and respond as fast
      and accurately as you can."
    french: "Dans cette exp\xE9rience, vous verrez deux lumi\xE8res s'approcher de
      vous.\n\nDe temps en temps, vous sentirez une br\xE8ve vibration sur votre
      poitrine.\n\nVotre objectif est de:\n  \u2022 Vous concentrer sur les lumi\xE8res
      qui approchent.\n  \u2022 R\xE9pondre aussi rapidement que possible lorsque
      vous sentez la vibration.\n  \u2022 Appuyer sur le bouton de r\xE9ponse d\xE8s
      que vous d\xE9tectez le contact.\n\nGardez la main pr\xEAte sur le bouton et
      r\xE9pondez aussi vite et pr\xE9cis\xE9ment que possible."
  - key: pps.practice_intro
    english: 'We will start with a few practice trials so you can get used to the
      lights and the vibration.


      These trials will not be recorded.


      When
      you are ready, press Continue.'
    french: "Nous allons commencer par quelques essais d'entra\xEEnement pour que
      vous vous habituiez aux lumi\xE8res et \xE0 la vibration.\n\nCes essais ne
      seront pas enregistr\xE9s.\n\nLorsque vous \xEAtes pr\xEAt, appuyez sur Continuer."
  - key: pps.block_intro
    english: 'The next block is about to begin.


      Stay still, focus on the
      lights, and respond as quickly as you can when you feel a vibration.


      Press
      Continue when you are ready.'
    french: "Le prochain bloc va commencer.\n\nRestez immobile, concentrez-vous sur
      les lumi\xE8res, et r\xE9pondez aussi rapidement que possible lorsque vous
      sentez une vibration.\n\nAppuyez sur Continuer lorsque vous \xEAtes pr\xEAt."
  - key: pps.rest
    english: 'Take a short break.


      The next block will begin shortly.'
    french: "Faites une courte pause.\n\nLe prochain bloc commencera bient\xF4t."
  - key: pps.outro
    english: "End of the experiment \u2014 Thank you for participating!"
    french: "Fin de l'exp\xE9rience \u2014 Merci d'avoir particip\xE9 !"
  - key: popup1_intro
    english: Hit or Miss Task\n\nIn this task, an object will come towards you. Determine
      whether it will HIT or MISS you. Stay still and respond using the LEFT and
      RIGHT controllers as quickly and accurately as possible.\n\nLet's try a little
      practice.
    french: "T\xE2che Hit or Miss\\n\\nDans cette t\xE2che, un objet s'approchera
      de vous. D\xE9terminez s'il va vous TOUCHER ou vous MANQUER. Restez immobile
      et r\xE9pondez avec les manettes GAUCHE et DROITE aussi vite et pr\xE9cis\xE9ment
      que possible.\\n\\nFaisons un petit exercice."
  - key: popup2_left
    english: A ball will come towards you.\nPress LEFT if you think the ball will
      HIT you.\nPress LEFT now.
    french: "Une balle viendra vers vous.\\nAppuyez \xE0 GAUCHE si vous pensez qu'elle
      va vous TOUCHER.\\nAppuyez \xE0 GAUCHE maintenant."
  - key: popup3_right
    english: Now press RIGHT if you think the ball will MISS you.\nPress RIGHT now.
    french: "Maintenant, appuyez \xE0 DROITE si vous pensez qu'elle va vous MANQUER.\\nAppuyez
      \xE0 DROITE maintenant."
  - key: popup4_practice
    english: Now let's put it into practice.
    french: Maintenant, mettons-le en pratique.
  - key: popup5_ready
    english: Ok. Now you are all set.\n\nDuring the task, you will not receive any
      feedback. Just respond as quickly and accurately as you can.
    french: "D'accord. Vous \xEAtes pr\xEAt(e).\\n\\nPendant la t\xE2che, vous ne
      recevrez aucun retour. R\xE9pondez simplement aussi vite et pr\xE9cis\xE9ment
      que possible."
  - key: popup6_block_intro
    english: Let's start with Block {block}.
    french: "Commen\xE7ons avec le Bloc {block}"
  - key: popup7_break
    english: All done with Block {block}. Take a little break.
    french: "Bloc {block} termin\xE9. Prenez une petite pause."
  - key: popup8_next_block
    english: Are you ready to start with Block {block}? Let's go!
    french: "Pr\xEAt(e) \xE0 commencer le Bloc {block} ? Allons-y !"
  - key: popup9_outro
    english: You are all done. Thank you for your participation.
    french: "C'est termin\xE9. Merci pour votre participation."
