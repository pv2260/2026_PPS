%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 90a31742b4988d64896200d05b98a005, type: 3}
  m_Name: HitOrMissTermTable
  m_EditorClassIdentifier: 
  m_Entries:
  - key: instruction_title
    english: Hit or Miss
    french: "Touche ou Rat\xE9"
  - key: instruction_body
    english: 'A ball will approach you from a distance.

      Your task is to predict
      whether it will HIT you or MISS you.


      The ball will disappear before
      reaching you,

      so you must judge from its trajectory.


      Press the
      LEFT trigger if you think it will HIT you.

      Press the RIGHT trigger if
      you think it will MISS you.


      Respond as quickly and accurately as you
      can.

      There are 80 trials per block. Please stay still.'
    french: "Une balle s'approchera de vous depuis une certaine distance.\nVotre
      t\xE2che est de pr\xE9dire si elle va vous TOUCHER ou vous RATER.\n\nLa balle
      dispara\xEEtra avant de vous atteindre,\nvous devez donc juger \xE0 partir
      de sa trajectoire.\n\nAppuyez sur la g\xE2chette GAUCHE si vous pensez qu'elle
      va vous TOUCHER.\nAppuyez sur la g\xE2chette DROITE si vous pensez qu'elle
      va vous RATER.\n\nR\xE9pondez aussi vite et pr\xE9cis\xE9ment que possible.\nIl
      y a 80 essais par bloc. Veuillez rester immobile."
  - key: block_complete
    english: "Block completed \u2014 take a small break"
    french: "Bloc termin\xE9 \u2014 faites une courte pause"
  - key: experiment_end
    english: "End of the experiment \u2014 Thank you!"
    french: "Fin de l'exp\xE9rience \u2014 Merci !"
  - key: rest_message
    english: Please rest. The next block will begin shortly.
    french: "Veuillez vous reposer. Le prochain bloc commencera bient\xF4t."
  - key: ready
    english: Ready
    french: "Pr\xEAt"
  - key: say_hit
    english: HIT
    french: TOUCHE
  - key: say_miss
    english: MISS
    french: "RAT\xC9"
  - key: pps.instructions
    english: "In this experiment, you will see two lights approaching you.\n\nOccasionally,
      you will feel a brief vibration on your chest.\n\nYour goal is to:\n  •
      Focus on the approaching lights.\n  • Respond as quickly as possible when
      you feel the vibration.\n  • Press the response button the moment you
      detect the touch.\n\nKeep your hand ready on the button and respond as fast
      and accurately as you can."
    french: "Dans cette exp\xE9rience, vous verrez deux lumi\xE8res s'approcher de
      vous.\n\nDe temps en temps, vous sentirez une br\xE8ve vibration sur votre
      poitrine.\n\nVotre objectif est de:\n  • Vous concentrer sur les lumi\xE8res
      qui approchent.\n  • R\xE9pondre aussi rapidement que possible lorsque
      vous sentez la vibration.\n  • Appuyer sur le bouton de r\xE9ponse d\xE8s
      que vous d\xE9tectez le contact.\n\nGardez la main pr\xEAte sur le bouton et
      r\xE9pondez aussi vite et pr\xE9cis\xE9ment que possible."
  - key: pps.practice_intro
    english: "We will start with a few practice trials so you can get used to the
      lights and the vibration.\n\nThese trials will not be recorded.\n\nWhen you
      are ready, press Continue."
    french: "Nous allons commencer par quelques essais d'entra\xEEnement pour que
      vous vous habituiez aux lumi\xE8res et \xE0 la vibration.\n\nCes essais ne
      seront pas enregistr\xE9s.\n\nLorsque vous \xEAtes pr\xEAt, appuyez sur Continuer."
  - key: pps.block_intro
    english: "The next block is about to begin.\n\nStay still, focus on the lights,
      and respond as quickly as you can when you feel a vibration.\n\nPress Continue
      when you are ready."
    french: "Le prochain bloc va commencer.\n\nRestez immobile, concentrez-vous sur
      les lumi\xE8res, et r\xE9pondez aussi rapidement que possible lorsque vous
      sentez une vibration.\n\nAppuyez sur Continuer lorsque vous \xEAtes pr\xEAt."
  - key: pps.rest
    english: "Take a short break.\n\nThe next block will begin shortly."
    french: "Faites une courte pause.\n\nLe prochain bloc commencera bient\xF4t."
  - key: pps.outro
    english: "End of the experiment — Thank you for participating!"
    french: "Fin de l'exp\xE9rience — Merci d'avoir particip\xE9 !"
  - key: pps.vibration_message
    english: VIBRATION
    french: VIBRATION
